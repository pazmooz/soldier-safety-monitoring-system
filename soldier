#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

#define MPU_ADDR 0x68
#define BUTTON_PIN 3
#define BUZZER_PIN 8

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// ---------------- SYSTEM STATE ----------------
enum SystemState {
  SAFE_STATE,
  COUNTDOWN_STATE,
  SOS_STATE
};

SystemState state = SAFE_STATE;

// ---------------- GPS DEMO ----------------
double latitude = 53.1238;
double longitude = 18.0107;

// ---------------- SENSOR ----------------
float accelerationG = 1.0;

// ---------------- TIMER ----------------
unsigned long countdownStart = 0;
const unsigned long countdownTime = 10000;

// ---------------- BUTTON ----------------
int buttonPressCount = 0;
unsigned long lastButtonPress = 0;

// ---------------- DISPLAY ----------------
unsigned long lastDisplayUpdate = 0;
unsigned long lastSerialSend = 0;

// ---------------- OLED PAGES ----------------
int sosPage = 0;   // 0 = status, 1 = soldier info

// ---------------- SOLDIER DATA ----------------
struct Soldier {
  String name;
  String number;
  String bloodType;
  float height;
  float weight;
  String unit;
  String allergies;
  String healthHistory;
};

Soldier soldier = {
  "OSCAR BOBB",
  "010101",
  "O+",
  180.0,
  75.0,
  "ALPHA UNIT",
  "NONE",
  "NO MAJOR HISTORY"
};

// ---------------- MPU ----------------
void mpuWrite(byte reg, byte data) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  Wire.write(data);
  Wire.endTransmission();
}

bool readMPU() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);

  if (Wire.endTransmission(false) != 0) return false;
  if (Wire.requestFrom(MPU_ADDR, 6) != 6) return false;

  int16_t ax = (Wire.read() << 8) | Wire.read();
  int16_t ay = (Wire.read() << 8) | Wire.read();
  int16_t az = (Wire.read() << 8) | Wire.read();

  float fax = ax / 16384.0;
  float fay = ay / 16384.0;
  float faz = az / 16384.0;

  accelerationG = sqrt(fax * fax + fay * fay + faz * faz);
  return true;
}

// ---------------- FALL DETECTION ----------------
bool fallDetected() {
  static unsigned long freeFallTime = 0;

  if (accelerationG < 0.35) {
    freeFallTime = millis();
  }

  if (freeFallTime > 0 &&
      millis() - freeFallTime < 1500 &&
      accelerationG > 2.30) {
    freeFallTime = 0;
    return true;
  }

  if (freeFallTime > 0 &&
      millis() - freeFallTime > 1500) {
    freeFallTime = 0;
  }

  return false;
}

// ---------------- BUTTON ----------------
void checkButton() {

  static bool lastState = HIGH;
  bool currentState = digitalRead(BUTTON_PIN);

  if (lastState == HIGH && currentState == LOW) {

    unsigned long now = millis();

    if (now - lastButtonPress < 1000)
      buttonPressCount++;
    else
      buttonPressCount = 1;

    lastButtonPress = now;

    Serial.print("PRESS COUNT: ");
    Serial.println(buttonPressCount);

    // ---------------- RESET EVERYTHING (10 presses) ----------------
    if (buttonPressCount >= 10) {

      state = SAFE_STATE;
      sosPage = 0;
      buttonPressCount = 0;
      countdownStart = 0;

      Serial.println("SYSTEM RESET");

      delay(300);
      lastState = currentState;
      return;
    }

    // ---------------- ENTER SOS (3 presses) ----------------
    if (state != SOS_STATE && buttonPressCount >= 3) {
      state = SOS_STATE;
      buttonPressCount = 0;
      sosPage = 0;

      Serial.println("SOS ACTIVATED");
    }

    // ---------------- SOS DETAILS PAGE (5 presses only in SOS) ----------------
    if (state == SOS_STATE && buttonPressCount >= 5) {
      sosPage = 1;
      buttonPressCount = 0;

      Serial.println("SOLDIER INFO PAGE");
    }

    delay(50);
  }

  lastState = currentState;
}

// ---------------- BUZZER ----------------
void doubleBeep() {
  tone(BUZZER_PIN, 1200);
  delay(200);
  noTone(BUZZER_PIN);
  delay(200);
  tone(BUZZER_PIN, 1200);
  delay(200);
  noTone(BUZZER_PIN);
}

// ---------------- OLED ----------------
void drawScreen() {

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0);

  // ---------------- SAFE ----------------
  if (state == SAFE_STATE) {
    display.println("STATUS: SAFE");
    display.print("ACC: ");
    display.println(accelerationG, 2);
  }

  // ---------------- COUNTDOWN ----------------
  if (state == COUNTDOWN_STATE) {
    display.println("STATUS: WARNING");

    long remaining = 10 - ((millis() - countdownStart) / 1000);
    display.print("SOS IN: ");
    display.println(remaining);
  }

  // ---------------- SOS MODE ----------------
  if (state == SOS_STATE) {

    if (sosPage == 0) {
      display.println("STATUS: SOS ACTIVE");
      display.print("LAT:");
      display.println(latitude, 4);
      display.print("LNG:");
      display.println(longitude, 4);
      display.print("ACC:");
      display.println(accelerationG, 2);
      display.println("PRESS 5X FOR INFO");
    }

    // ---------------- SOLDIER INFO PAGE ----------------
    if (sosPage == 1) {
      display.println("SOLDIER INFO");
      display.print("NAME: ");
      display.println(soldier.name);
      display.print("ID: ");
      display.println(soldier.number);
      display.print("BLOOD: ");
      display.println(soldier.bloodType);
      display.print("UNIT: ");
      display.println(soldier.unit);
      display.print("H: ");
      display.print(soldier.height);
      display.print(" W: ");
      display.println(soldier.weight);
      display.print("ALLERGY: ");
      display.println(soldier.allergies);
    }
  }

  display.display();
}

// ---------------- SERIAL ----------------
void sendSerial() {

  if (state == SOS_STATE) {
    Serial.print("SOS|");
    Serial.print(latitude, 6);
    Serial.print("|");
    Serial.println(longitude, 6);
  } else {
    Serial.print("SAFE|");
    Serial.print(accelerationG, 2);
    Serial.print("|");
    Serial.print(latitude, 6);
    Serial.print("|");
    Serial.println(longitude, 6);
  }
}

// ---------------- SETUP ----------------
void setup() {

  Serial.begin(115200);

  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);

  Wire.begin();
  delay(500);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    while (1);
  }

  display.clearDisplay();
  display.setTextSize(2);
  display.setCursor(10, 20);
  display.println("BOOT");
  display.display();

  delay(2000);

  mpuWrite(0x6B, 0x00);

  Serial.println("SYSTEM READY");
}

// ---------------- LOOP ----------------
void loop() {

  readMPU();
  checkButton();

  if (state == SAFE_STATE && fallDetected()) {
    Serial.println("FALL DETECTED");
    doubleBeep();
    countdownStart = millis();
    state = COUNTDOWN_STATE;
  }

  if (state == COUNTDOWN_STATE) {
    if (millis() - countdownStart >= countdownTime) {
      Serial.println("SOS AUTO TRIGGER");
      state = SOS_STATE;
    }
  }

  noTone(BUZZER_PIN);

  if (millis() - lastDisplayUpdate > 250) {
    lastDisplayUpdate = millis();
    drawScreen();
  }

  if (millis() - lastSerialSend > 1000) {
    lastSerialSend = millis();
    sendSerial();
  }
}
