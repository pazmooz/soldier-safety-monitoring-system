#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <math.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

#define MPU_ADDR 0x68

#define BUTTON_PIN 3
#define BUZZER_PIN 8

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

enum SystemState {
  SAFE_STATE,
  COUNTDOWN_STATE,
  SOS_STATE
};

SystemState state = SAFE_STATE;

// Demo GPS
double latitude = 53.1238;
double longitude = 18.0107;
bool gpsFix = true;

float accelerationG = 1.0;

unsigned long countdownStart = 0;
const unsigned long countdownTime = 10000;

int buttonPressCount = 0;
unsigned long lastButtonPress = 0;

unsigned long lastDisplayUpdate = 0;
unsigned long lastSerialSend = 0;

// ---------------- SOLDIER INFO MODE ----------------
bool infoMode = false;
unsigned long infoModeStart = 0;

String soldierName = "Monzer Mohamed";
String soldierID = "037607";
String bloodType = "O+";
float heightCM = 180;
float weightKG = 75;
String allergies = "None";
String medicalHistory = "None";

// ---------------- MPU ----------------
void mpuWrite(byte reg, byte data) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  Wire.write(data);
  Wire.endTransmission();
}

bool readMPU() {

  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);

  if (Wire.endTransmission(false) != 0)
    return false;

  if (Wire.requestFrom(MPU_ADDR, 6) != 6)
    return false;

  int16_t ax = (Wire.read() << 8) | Wire.read();
  int16_t ay = (Wire.read() << 8) | Wire.read();
  int16_t az = (Wire.read() << 8) | Wire.read();

  float fax = ax / 16384.0;
  float fay = ay / 16384.0;
  float faz = az / 16384.0;

  accelerationG = sqrt(fax * fax + fay * fay + faz * faz);

  return true;
}

// ---------------- FALL DETECTION ----------------
bool fallDetected() {

  static unsigned long freeFallTime = 0;

  if (accelerationG < 0.35) {
    freeFallTime = millis();
  }

  if (freeFallTime > 0 &&
      millis() - freeFallTime < 1500 &&
      accelerationG > 2.30) {

    freeFallTime = 0;
    return true;
  }

  if (freeFallTime > 0 &&
      millis() - freeFallTime > 1500) {
    freeFallTime = 0;
  }

  return false;
}

// ---------------- BUTTON ----------------
void checkButton() {

  static bool lastState = HIGH;
  bool currentState = digitalRead(BUTTON_PIN);

  if (lastState == HIGH && currentState == LOW) {

    unsigned long now = millis();

    if (now - lastButtonPress < 1000)
      buttonPressCount++;
    else
      buttonPressCount = 1;

    lastButtonPress = now;

    Serial.print("BUTTON COUNT: ");
    Serial.println(buttonPressCount);

    if (buttonPressCount == 5) {
      infoMode = true;
      infoModeStart = millis();
      buttonPressCount = 0;
      Serial.println("INFO MODE ON");
    }

    else if (buttonPressCount >= 3) {
      state = SOS_STATE;
      buttonPressCount = 0;
      Serial.println("SOS MANUAL");
    }

    if (state == COUNTDOWN_STATE) {
      state = SAFE_STATE;
      Serial.println("CANCELLED");
    }

    delay(50);
  }

  lastState = currentState;
}

// ---------------- BUZZER ----------------
void doubleBeep() {
  tone(BUZZER_PIN, 1200);
  delay(200);
  noTone(BUZZER_PIN);
  delay(200);
  tone(BUZZER_PIN, 1200);
  delay(200);
  noTone(BUZZER_PIN);
}

// ---------------- OLED ----------------
void drawScreen() {

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0);

  if (state == SAFE_STATE) display.println("STATUS: SAFE");
  if (state == COUNTDOWN_STATE) display.println("STATUS: WARNING");
  if (state == SOS_STATE) display.println("STATUS: SOS");

  display.print("ACC: ");
  display.println(accelerationG, 2);

  display.println("GPS DEMO");

  display.print("LAT:");
  display.println(latitude, 4);

  display.print("LNG:");
  display.println(longitude, 4);

  if (state == COUNTDOWN_STATE) {
    long remaining = 10 - ((millis() - countdownStart) / 1000);
    display.print("SOS IN: ");
    display.println(remaining);
  }

  if (state == SOS_STATE) {
    display.println("SOS ACTIVE");
  }

  display.display();
}

// ---------------- INFO SCREEN ----------------
void drawInfoScreen() {

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);

  display.setCursor(0, 0);
  display.println("SOLDIER INFO");
  display.println("----------------");

  display.print("Name:");
  display.println(soldierName);

  display.print("ID:");
  display.println(soldierID);

  display.print("Blood:");
  display.println(bloodType);

  display.print("H:");
  display.print(heightCM);
  display.print(" W:");
  display.println(weightKG);

  float bmi = weightKG / ((heightCM / 100.0) * (heightCM / 100.0));

  display.print("BMI:");
  display.println(bmi, 1);

  display.print("Allergy:");
  display.println(allergies);

  display.print("Hist:");
  display.println(medicalHistory);

  display.display();
}

// ---------------- SERIAL ----------------
void sendSerial() {

  if (state == SOS_STATE) {
    Serial.print("SOS|");
    Serial.print(latitude, 6);
    Serial.print("|");
    Serial.println(longitude, 6);
    return;
  }

  Serial.print("SAFE|");
  Serial.print(accelerationG, 2);
  Serial.print("|");
  Serial.print(latitude, 6);
  Serial.print("|");
  Serial.println(longitude, 6);
}

// ---------------- SETUP ----------------
void setup() {

  Serial.begin(115200);

  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);

  Wire.begin();

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    while (1);
  }

  display.clearDisplay();
  display.setTextSize(2);
  display.setCursor(10, 20);
  display.println("BOOT");
  display.display();

  delay(2000);

  mpuWrite(0x6B, 0x00);

  Serial.println("READY");
}

// ---------------- LOOP ----------------
void loop() {

  readMPU();
  checkButton();

  if (!infoMode) {

    if (state == SAFE_STATE && fallDetected()) {
      Serial.println("FALL DETECTED");
      doubleBeep();
      countdownStart = millis();
      state = COUNTDOWN_STATE;
    }

    if (state == COUNTDOWN_STATE) {
      if (millis() - countdownStart >= countdownTime) {
        state = SOS_STATE;
      }
    }
  }

  noTone(BUZZER_PIN);

  // INFO MODE SCREEN
  if (infoMode) {

    drawInfoScreen();

    if (millis() - infoModeStart > 8000) {
      infoMode = false;
    }

  } else {

    if (millis() - lastDisplayUpdate > 250) {
      lastDisplayUpdate = millis();
      drawScreen();
    }
  }

  if (millis() - lastSerialSend > 1000) {
    lastSerialSend = millis();
    sendSerial();
  }
}
