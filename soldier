#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <math.h>

// =====================================================
// HARDWARE CONFIGURATION
// =====================================================
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define MPU_ADDR 0x68

#define BUTTON_PIN 3
#define BUZZER_PIN 8

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// =====================================================
// SYSTEM STATES
// =====================================================
enum SystemState {
  SAFE_STATE,
  COUNTDOWN_STATE,
  SOS_STATE,
  INFO_STATE,
  DIAGNOSTIC_STATE
};

SystemState state = SAFE_STATE;

// =====================================================
// SOLDIER PROFILE SYSTEM (EXPANDED)
// =====================================================
struct SoldierProfile {
  String name;
  String id;
  String unit;
  String bloodType;
  String height;
  String weight;
  String bmi;
  String allergies;
  String medicalHistory;
};

SoldierProfile soldier = {
  "OSCAR BOBB",
  "010101",
  "ALPHA",
  "O+",
  "180cm",
  "75kg",
  "23.1",
  "NONE",
  "NONE"
};

// =====================================================
// GPS DEMO DATA
// =====================================================
double latitude = 53.1238;
double longitude = 18.0107;

// =====================================================
// SENSOR DATA
// =====================================================
float accelerationG = 1.0;

// =====================================================
// TIMERS
// =====================================================
unsigned long countdownStart = 0;
const unsigned long countdownTime = 10000;

unsigned long lastDisplayUpdate = 0;
unsigned long lastSerialSend = 0;

// =====================================================
// BUTTON SYSTEM
// =====================================================
int buttonPressCount = 0;
unsigned long lastButtonPress = 0;

// =====================================================
// DEBUG SYSTEM (NEW)
// =====================================================
bool debugMode = true;

void debugPrint(String msg) {
  if (debugMode) {
    Serial.print("[DEBUG] ");
    Serial.println(msg);
  }
}

// =====================================================
// MPU FUNCTIONS
// =====================================================
void mpuWrite(byte reg, byte data) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  Wire.write(data);
  Wire.endTransmission();
}

bool readMPU() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);

  if (Wire.endTransmission(false) != 0) return false;
  if (Wire.requestFrom(MPU_ADDR, 6) != 6) return false;

  int16_t ax = (Wire.read() << 8) | Wire.read();
  int16_t ay = (Wire.read() << 8) | Wire.read();
  int16_t az = (Wire.read() << 8) | Wire.read();

  float fx = ax / 16384.0;
  float fy = ay / 16384.0;
  float fz = az / 16384.0;

  accelerationG = sqrt(fx * fx + fy * fy + fz * fz);
  return true;
}

// =====================================================
// FALL DETECTION ALGORITHM
// =====================================================
bool fallDetected() {
  static unsigned long freeFallTime = 0;

  if (accelerationG < 0.35) {
    freeFallTime = millis();
    debugPrint("Free fall detected");
  }

  if (freeFallTime > 0 &&
      millis() - freeFallTime < 1500 &&
      accelerationG > 2.3) {

    freeFallTime = 0;
    debugPrint("Impact detected");
    return true;
  }

  if (freeFallTime > 0 &&
      millis() - freeFallTime > 1500) {
    freeFallTime = 0;
  }

  return false;
}

// =====================================================
// BUTTON SYSTEM (5 PRESS = INFO, 6 PRESS = DIAGNOSTIC)
// =====================================================
void checkButton() {

  static bool lastState = HIGH;
  bool currentState = digitalRead(BUTTON_PIN);

  if (lastState == HIGH && currentState == LOW) {

    unsigned long now = millis();

    if (now - lastButtonPress < 1000)
      buttonPressCount++;
    else
      buttonPressCount = 1;

    lastButtonPress = now;

    debugPrint("Button press: " + String(buttonPressCount));

    // 3 PRESS = SOS
    if (buttonPressCount == 3) {
      state = SOS_STATE;
      buttonPressCount = 0;
    }

    // 5 PRESS = INFO
    if (buttonPressCount == 5) {
      state = INFO_STATE;
      buttonPressCount = 0;
    }

    // 6 PRESS = DIAGNOSTIC MODE
    if (buttonPressCount == 6) {
      state = DIAGNOSTIC_STATE;
      buttonPressCount = 0;
    }

    // cancel countdown
    if (state == COUNTDOWN_STATE) {
      state = SAFE_STATE;
    }
  }

  lastState = currentState;
}

// =====================================================
// BUZZER ALERT
// =====================================================
void alertBeep() {
  tone(BUZZER_PIN, 1200); delay(150);
  noTone(BUZZER_PIN); delay(150);
  tone(BUZZER_PIN, 1200); delay(150);
  noTone(BUZZER_PIN);
}

// =====================================================
// ENCRYPTION STUB (THESIS FEATURE)
// =====================================================
String encryptPacket(String input) {
  String output = "";

  for (int i = 0; i < input.length(); i++) {
    output += char(input[i] + 3); // simple Caesar shift
  }

  return output;
}

// =====================================================
// SERIAL COMMUNICATION
// =====================================================
void sendSerial() {

  String packet;

  if (state == SOS_STATE) {
    packet = "SOS|" + String(latitude, 6) + "|" + String(longitude, 6);
  } else {
    packet = "SAFE|" + String(accelerationG, 2);
  }

  String encrypted = encryptPacket(packet);

  Serial.println(encrypted);
}

// =====================================================
// OLED SCREENS
// =====================================================
void drawInfoScreen() {

  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(0, 0);

  display.println("SOLDIER INFO");
  display.println("----------------");

  display.println("NAME: " + soldier.name);
  display.println("ID: " + soldier.id);
  display.println("UNIT: " + soldier.unit);
  display.println("BLOOD: " + soldier.bloodType);
  display.println("BMI: " + soldier.bmi);
  display.println("H: " + soldier.height);
  display.println("W: " + soldier.weight);
  display.println("ALLERGY: " + soldier.allergies);

  display.display();
}

void drawDiagnosticScreen() {

  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(0, 0);

  display.println("SYSTEM DIAGNOSTIC");
  display.println("----------------");

  display.print("ACC: ");
  display.println(accelerationG);

  display.print("STATE: ");
  display.println(state);

  display.print("BUTTONS: ");
  display.println(buttonPressCount);

  display.print("GPS OK");

  display.display();
}

// =====================================================
// NORMAL SCREEN
// =====================================================
void drawScreen() {

  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(0, 0);

  if (state == SAFE_STATE) display.println("STATUS: SAFE");
  if (state == COUNTDOWN_STATE) display.println("STATUS: WARNING");
  if (state == SOS_STATE) display.println("STATUS: SOS");

  display.print("ACC: "); display.println(accelerationG);
  display.print("LAT: "); display.println(latitude);
  display.print("LNG: "); display.println(longitude);

  if (state == COUNTDOWN_STATE) {
    long remaining = 10 - ((millis() - countdownStart) / 1000);
    display.print("SOS IN: ");
    display.println(remaining);
  }

  display.display();
}

// =====================================================
// SETUP
// =====================================================
void setup() {

  Serial.begin(115200);
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);

  Wire.begin();

  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);

  display.clearDisplay();
  display.setTextSize(2);
  display.setCursor(10, 20);
  display.println("BOOT");
  display.display();

  delay(2000);

  mpuWrite(0x6B, 0x00);

  debugPrint("SYSTEM INITIALIZED");
}

// =====================================================
// LOOP
// =====================================================
void loop() {

  readMPU();
  checkButton();

  if (state == SAFE_STATE && fallDetected()) {
    alertBeep();
    countdownStart = millis();
    state = COUNTDOWN_STATE;
  }

  if (state == COUNTDOWN_STATE &&
      millis() - countdownStart > countdownTime) {
    state = SOS_STATE;
  }

  noTone(BUZZER_PIN);

  if (state == INFO_STATE) drawInfoScreen();
  else if (state == DIAGNOSTIC_STATE) drawDiagnosticScreen();
  else drawScreen();

  if (millis() - lastSerialSend > 1000) {
    lastSerialSend = millis();
    sendSerial();
  }
}
