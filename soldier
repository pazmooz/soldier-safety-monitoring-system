#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <math.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

#define MPU_ADDR 0x68
#define BUTTON_PIN 3
#define BUZZER_PIN 8

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// ---------------- STATES ----------------
enum SystemState {
  SAFE_STATE,
  COUNTDOWN_STATE,
  SOS_STATE
};

SystemState state = SAFE_STATE;

// ---------------- GPS (DEMO) ----------------
float latitude = 53.1238;
float longitude = 18.0107;

// ---------------- SENSOR ----------------
float accelerationG = 1.0;

// ---------------- TIMERS ----------------
unsigned long countdownStart = 0;
const unsigned long countdownTime = 10000;

unsigned long lastDisplayUpdate = 0;
unsigned long lastSerialSend = 0;

// ---------------- BUTTON ----------------
int pressCount = 0;
unsigned long lastPressTime = 0;

// ---------------- INFO SCROLL ----------------
int infoPage = 0;
unsigned long lastScroll = 0;

// ---------------- SOLDIER DATA ----------------
String soldierName = "OSCAR BOBB";
String soldierNumber = "010101";
String bloodType = "O+";
String unitName = "ALPHA UNIT";
String height = "180cm";
String weight = "75kg";
String bmi = "23.1";
String allergies = "NONE";

// ---------------- MPU ----------------
void mpuWrite(byte reg, byte data) {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(reg);
  Wire.write(data);
  Wire.endTransmission();
}

bool readMPU() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);

  if (Wire.endTransmission(false) != 0) return false;
  if (Wire.requestFrom(MPU_ADDR, 6) != 6) return false;

  int16_t ax = (Wire.read() << 8) | Wire.read();
  int16_t ay = (Wire.read() << 8) | Wire.read();
  int16_t az = (Wire.read() << 8) | Wire.read();

  float fax = ax / 16384.0;
  float fay = ay / 16384.0;
  float faz = az / 16384.0;

  accelerationG = sqrt(fax * fax + fay * fay + faz * faz);
  return true;
}

// ---------------- FALL DETECTION ----------------
bool fallDetected() {
  static unsigned long freeFallTime = 0;

  if (accelerationG < 0.35) freeFallTime = millis();

  if (freeFallTime && millis() - freeFallTime < 1500 && accelerationG > 2.3) {
    freeFallTime = 0;
    return true;
  }

  if (freeFallTime && millis() - freeFallTime > 1500) freeFallTime = 0;

  return false;
}

// ---------------- RESET ----------------
void resetSystem() {
  state = SAFE_STATE;
  pressCount = 0;
  infoPage = 0;
  countdownStart = 0;
  noTone(BUZZER_PIN);
}

// ---------------- BUTTON ----------------
void handleButton() {
  static bool lastState = HIGH;
  bool current = digitalRead(BUTTON_PIN);

  if (lastState == HIGH && current == LOW) {

    unsigned long now = millis();

    if (now - lastPressTime < 800)
      pressCount++;
    else
      pressCount = 1;

    lastPressTime = now;

    // RESET (10 presses)
    if (pressCount >= 10) {
      resetSystem();
      Serial.println("RESET");
    }

    // CANCEL COUNTDOWN (1 press)
    if (state == COUNTDOWN_STATE) {
      state = SAFE_STATE;
      countdownStart = 0;
      pressCount = 0;
      Serial.println("COUNTDOWN CANCELLED");
    }

    // MANUAL SOS (3 presses)
    if (pressCount == 3 && state != SOS_STATE) {
      state = SOS_STATE;
    }

    // INFO MODE (5 presses in SOS)
    if (pressCount == 5 && state == SOS_STATE) {
      infoPage = 0;
    }

    delay(30);
  }

  lastState = current;
}

// ---------------- BUZZER ----------------
void doubleBeep() {
  tone(BUZZER_PIN, 1200); delay(150);
  noTone(BUZZER_PIN); delay(150);
  tone(BUZZER_PIN, 1200); delay(150);
  noTone(BUZZER_PIN);
}

// ---------------- DISPLAY ----------------
void drawScreen() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0);

  if (state == SAFE_STATE) display.println("STATUS: SAFE");
  if (state == COUNTDOWN_STATE) display.println("STATUS: WARNING");
  if (state == SOS_STATE) display.println("STATUS: SOS");

  display.print("ACC:");
  display.println(accelerationG, 2);

  display.print("LAT:");
  display.println(latitude, 4);

  display.print("LNG:");
  display.println(longitude, 4);

  // countdown
  if (state == COUNTDOWN_STATE) {
    long remaining = 10 - ((millis() - countdownStart) / 1000);
    display.print("SOS IN:");
    display.println(remaining);
  }

  // soldier info
  if (state == SOS_STATE && pressCount >= 5) {

    if (millis() - lastScroll > 2000) {
      lastScroll = millis();
      infoPage = (infoPage + 1) % 4;
    }

    display.println("---- SOLDIER ----");

    if (infoPage == 0) {
      display.println("NAME:");
      display.println(soldierName);
    }

    if (infoPage == 1) {
      display.println("ID:");
      display.println(soldierNumber);
      display.println(bloodType);
    }

    if (infoPage == 2) {
      display.println("UNIT:");
      display.println(unitName);
    }

    if (infoPage == 3) {
      display.println("BODY:");
      display.print(height); display.print(" ");
      display.println(weight);
      display.print("BMI:");
      display.println(bmi);
      display.println(allergies);
    }
  }

  display.display();
}

// ---------------- SERIAL ----------------
void sendSerial() {
  Serial.print(state == SOS_STATE ? "SOS|" : "SAFE|");
  Serial.print(accelerationG);
  Serial.print("|");
  Serial.print(latitude, 6);
  Serial.print("|");
  Serial.println(longitude, 6);
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(115200);

  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);

  Wire.begin();

  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay();

  mpuWrite(0x6B, 0x00);

  Serial.println("SYSTEM READY");
}

// ---------------- LOOP ----------------
void loop() {

  readMPU();
  handleButton();

  if (state == SAFE_STATE && fallDetected()) {
    doubleBeep();
    countdownStart = millis();
    state = COUNTDOWN_STATE;
  }

  if (state == COUNTDOWN_STATE) {
    if (millis() - countdownStart >= countdownTime) {
      state = SOS_STATE;
    }
  }

  noTone(BUZZER_PIN);

  if (millis() - lastDisplayUpdate > 200) {
    lastDisplayUpdate = millis();
    drawScreen();
  }

  if (millis() - lastSerialSend > 1000) {
    lastSerialSend = millis();
    sendSerial();
  }
}
